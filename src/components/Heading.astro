---
// Henter parametrene fra Astro.props
const {
  htmlheading = "h2",
  size = "medium",
  font = "sans",
  weight = "bold",
  stylingclasses = "",
} = Astro.props;
const Htmlheading = htmlheading;

//Definer den styling (Tailwind classes), der gør sig gældende for de forskellige størrelser.
const sizeClasses = {
  large: "text-[2.5rem] md:text-[3rem] lg:text-[1.563rem]",
  medium: "text-[2.25rem] md:text-[2.5rem] lg:text-[1.25rem]",
  small: "text-[1.5rem] md:text-[1.75rem] lg:text-[0.938rem]",
};

const weightClasses = {
  light: "font-light leading-[1.2]",
  medium: "font-medium leading-[1.15]",
  semibold: "font-semibold leading-[1.1]",
  bold: "font-bold leading-[1.1] tracking-wide",
};

//Definer den styling (Tailwind classes), der gør sig gældende for de forskellige skrifttyper.
const fontClasses = {
  sans: "font-sans",
};

---

<Htmlheading
  class:list={[
    stylingclasses,
    sizeClasses[size],
    weightClasses[weight],
    fontClasses[font],
    'text-[var(--font-color-primary)]',
  ]}><slot /></Htmlheading
>
